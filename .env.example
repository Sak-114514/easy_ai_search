# ---------- Runtime ----------
OPENSEARCH_HOME=.
OPENSEARCH_DATA_DIR=./data
OPENSEARCH_LOG_DIR=./data/logs

# ---------- Search ----------
SEARXNG_API_URL=http://127.0.0.1:8080/search
SEARXNG_TIMEOUT=15.0
SEARXNG_MAX_RESULTS=5

# ---------- Render ----------
LIGHTPANDA_CDP_URL=ws://127.0.0.1:9222
LIGHTPANDA_TIMEOUT=10.0
LIGHTPANDA_MAX_CONCURRENT=5
LIGHTPANDA_RETRY_TIMES=2

# ---------- Vector DB ----------
CHROMA_PERSIST_DIR=./data/chroma_db
CHROMA_COLLECTION_NAME=ai_search
CHROMA_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
# CHROMA_EMBEDDING_MODEL_PATH=/absolute/path/to/local/embedding-model
CHROMA_TOP_K=3

# ---------- Cache ----------
CACHE_ENABLED=true
CACHE_TTL=3600
CACHE_PERSIST_DIR=./data/chroma_db_cache

# ---------- Process ----------
TEXT_CHUNK_SIZE=512
TEXT_OVERLAP=50

# ---------- Deep Process ----------
DEEP_SUMMARY_BACKEND=lmstudio
DEEP_SUMMARY_API_URL=http://127.0.0.1:1234
DEEP_SUMMARY_MODEL=google/gemma-3-1b
# DEEP_SUMMARY_MODEL_PATH=/absolute/path/to/local/summary-model
DEEP_SUMMARY_TIMEOUT=15.0
DEEP_SUMMARY_LENGTH=200
DEEP_MIN_QUALITY_SCORE=0.5
DEEP_DEDUP_THRESHOLD=0.85
DEEP_ENABLE_SUMMARY=true
DEEP_ENABLE_DEDUP=true
DEEP_ENABLE_QUALITY_CHECK=true

# ---------- Logging ----------
LOG_LEVEL=INFO
LOG_DIR=./data/logs
LOG_FILE=./data/logs/app.log

# ---------- API ----------
API_HOST=127.0.0.1
API_PORT=8000
API_DEBUG=false
DATABASE_URL=sqlite:///./data/logs.db

# ---------- Security ----------
# JSON format: {"admin": "your-secure-admin-key", "default": "your-default-key"}
API_KEYS_JSON='{"admin":"change-me-to-a-secure-key"}'
JWT_SECRET=change-me-to-a-secure-jwt-secret
CORS_ORIGINS=http://localhost:8000,http://127.0.0.1:8000
